# Environment Variables — Commission Crowd Agent
# Copy this file to .env and populate real values from the operator.
# Do NOT commit .env to version control.

# --- Ollama / LLM ---
OLLAMA_BASE_URL=
OLLAMA_API_KEY=
OLLAMA_MODEL=

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Google (Sheets, Drive, Gmail) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_APPLICATION_CREDENTIALS_PATH=
GOOGLE_SERVICE_ACCOUNT_JSON=

# --- Email / SMTP (fallback) ---
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# --- n8n (for export / metadata scripts) ---
N8N_BASE_URL=
N8N_API_KEY=
N8N_BASIC_AUTH_USER=
N8N_BASIC_AUTH_PASS=

# --- CommissionCrowd ---
COMMISSIONCROWD_API_KEY=
COMMISSIONCROWD_BASE_URL=https://www.commissioncrowd.com/api

# --- Commission Crowd Agent ---
CCA_CLIENT_NAME=
CCA_DAILY_VOLUME_LIMIT=
CCA_LOG_LEVEL=INFO

# --- Supervisor Relay (local model routing) ---
SUPERVISOR_MODE=local
SUPERVISOR_BASE_URL=http://localhost:11434/v1
SUPERVISOR_API_KEY=
SUPERVISOR_PRIMARY_MODEL=glm-5.1
SUPERVISOR_CODE_REVIEW_MODEL=qwen3-coder-next
SUPERVISOR_REASONING_FALLBACK_MODEL=deepseek-v3.2
SUPERVISOR_DRAFT_REVIEW_MODEL=kimi-k2-thinking
SMTP_FROM=publisher@syntaxis.online
